<idea-plugin url="https://github.com/zephir-lang/idea-plugin">
    <id>com.zephir</id>
    <name>Zephir</name>
    <vendor email="team@zephir-lang.com" url="https://zephir-lang.com">Zephir Team</vendor>

    <description><![CDATA[
    <p>Provides <a href="https://zephir-lang.com/en">Zephir language</a> support for IntelliJ IDEs.</p><br/>

    <a href="https://github.com/zephir-lang/idea-plugin">GitHub</a> |
    <a href="https://github.com/zephir-lang/idea-plugin/issues">Issues</a> |
    <a href="https://phalcon.io/fund">Donate</a><br/><br/>

    <p>
        Zephir is a high level language that eases the creation and maintainability
        of extensions for PHP. Zephir extensions are exported to C code that can be compiled
        and optimized by major C compilers such as gcc/clang/vc++. Functionality is exposed
        to the PHP language.
    </p>

    <h2>Highlighted Features</h2>
    <ul>
      <li>Syntax highlighting</li>
      <li>Syntax check support</li>
      <li><b>Autocompletion</b> — local variables, class/interface names from the project, PHP built-in functions, and member access (<code>-&gt;</code>) for Zephir-typed variables</li>
      <li><b>Structure View</b> — browse classes, interfaces, methods, properties, and constants via the IDE structure panel</li>
      <li><b>Code Folding</b> — fold class/interface bodies, method blocks, inline C blocks, and block comments</li>
      <li><b>Live Templates</b> — expand common Zephir snippets (class, functions, loops, try/catch) with short abbreviations</li>
      <li><b>Rename Refactoring</b> — rename classes, interfaces, methods, properties, and constants</li>
      <li><b>Implementations Gutter</b> — see subclass and implementation counts in the editor gutter</li>
      <li><b>Go To Declaration</b> — Ctrl+click a class or interface name to jump to its declaration; qualified names resolve via namespace path, aliases navigate to their use statement</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File-type Factory -->
        <fileType name="Zephir" language="Zephir" implementationClass="com.zephir.lang.core.ZephirFileType"
                  fieldName="INSTANCE" extensions="zep"/>
        <internalFileTemplate name="Zephir Class"/>
        <internalFileTemplate name="Zephir Interface"/>

        <!-- Parser -->
        <lang.parserDefinition language="Zephir"
                               implementationClass="com.zephir.lang.core.parser.ZephirParserDefinition"/>

        <!-- Syntax Highlighter -->
        <lang.syntaxHighlighterFactory language="Zephir"
                                       implementationClass="com.zephir.ide.highlight.ZephirSyntaxHighlighterFactory"/>

        <!-- Commenter -->
        <lang.commenter language="Zephir" implementationClass="com.zephir.ide.commenter.ZephirCommenter"/>

        <!-- Matchers -->
        <lang.braceMatcher language="Zephir" implementationClass="com.zephir.ide.typing.ZephirBraceMatcher"/>

        <!-- Completion -->
        <completion.contributor language="Zephir"
                                implementationClass="com.zephir.lang.core.completion.ZephirCompletionContributor"/>

        <!-- Color Settings -->
        <colorSettingsPage implementation="com.zephir.ide.color.ZephirColorSettingsPage"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory language="Zephir"
                                      implementationClass="com.zephir.ide.structure.ZephirStructureViewFactory"/>

        <!-- Line Markers -->
        <codeInsight.lineMarkerProvider language="Zephir"
                                        implementationClass="com.zephir.ide.linemarker.ZephirLineMarkerProvider"/>

        <!-- Code Folding -->
        <lang.foldingBuilder language="Zephir"
                             implementationClass="com.zephir.ide.folding.ZephirFoldingBuilder"/>

        <!-- Documentation (Ctrl+Q / hover) -->
        <lang.documentationProvider language="Zephir"
                                    implementationClass="com.zephir.ide.documentation.ZephirDocumentationProvider"/>

        <!-- Go To Declaration (Ctrl+click) -->
        <gotoDeclarationHandler implementation="com.zephir.ide.navigation.ZephirGotoDeclarationHandler"/>

        <!-- References (Find Usages, Rename across usages) -->
        <psi.referenceContributor language="Zephir"
                                  implementation="com.zephir.lang.core.psi.ZephirReferenceContributor"/>

        <!-- Rename Refactoring -->
        <lang.refactoringSupport language="Zephir"
                                 implementationClass="com.zephir.ide.refactoring.ZephirRefactoringSupportProvider"/>

        <!-- Live Templates -->
        <defaultLiveTemplates file="/liveTemplates/Zephir.xml"/>
        <liveTemplateContext implementation="com.zephir.ide.template.ZephirTemplateContext"
                             contextId="Zephir"/>
    </extensions>

    <actions>
        <action id="Zephir.NewFile" class="com.zephir.ide.actions.ZephirCreateFileAction"
                text="Zephir File" description="Create new Zephir file">
            <add-to-group group-id="NewGroup" relative-to-action="NewFile" anchor="before"/>
        </action>
    </actions>
</idea-plugin>
